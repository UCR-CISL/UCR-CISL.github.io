% team.bib — single source of truth for team roster (website) and UCR advising (CV)
%
% CV fields:
%   title       : student name (verbatim)
%   type        : degree label for pre-UCR showtype entries (PhD, MS, BS)
%   venue       : institution name
%   note        : for UCR PhD/MS/UG — SHORT dept, optionally ", co-advised with Dr. X"
%                 for Visitors — background description (e.g. "MS, UCSD")
%   year        : START year (for sorting — most-recently-started sorts first)
%   month       : START month (Winter=1, Spring=4, Summer=7, Fall=10)
%   addendum    : END date string, e.g. "pres." or "Summer 2025"
%                 + norange for single-semester / no-end-date entries
%   keywords    : nonumber + group tag (ucr-phd, ucr-ms, ucr-ug, ucr-visitor)
%                 + norange for single-semester entries
%
% Website fields (bib2yml_team.py → _data/team_auto.yml):
%   webtype     : PI / PHD / MS / BS / Visitor / Alumni (per degree)
%                 absent = entry not shown on website
%   avatar, email, web, github, linkedin, gscholar, twitter, facebook
%   webyear     : year override when website year ≠ bib year
%   next        : next position for alumni
%   department  : ONLY for PI entry (ECE, CSE); all other entries use note for display

